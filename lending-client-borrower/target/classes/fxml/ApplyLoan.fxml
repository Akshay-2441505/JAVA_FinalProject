<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.msme.borrower.controllers.ApplyLoanController" style="-fx-padding: 30;">
    
    <Label text="Apply for a New Loan" styleClass="title-1"/>

    <VBox spacing="15" styleClass="card" style="-fx-padding: 30;" maxWidth="600">
        
        <Label text="Requested Amount (₹)" styleClass="text-bold"/>
        <TextField fx:id="amountField" promptText="e.g. 500000" styleClass="text-field" />

        <Label text="Tenure (Months)" styleClass="text-bold"/>
        <TextField fx:id="tenureField" promptText="e.g. 24" styleClass="text-field" />

        <Label text="Loan Purpose" styleClass="text-bold"/>
        <ComboBox fx:id="purposeComboBox" promptText="Select Purpose" maxWidth="Infinity" />

        <VBox style="-fx-padding: 20 0 0 0;">
            <Button text="Submit Application" maxWidth="Infinity" styleClass="accent" onAction="#handleSubmit"/>
        </VBox>
    </VBox>

</VBox>
