<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.msme.admin.controllers.LoanListController" style="-fx-padding: 20;">
    
    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label text="Loan Applications" styleClass="title-1"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="Refresh Data" styleClass="accent"/>
    </HBox>

    <TableView fx:id="loanTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" text="App ID" prefWidth="150" />
            <TableColumn fx:id="borrowerColumn" text="Borrower Name" prefWidth="250" />
            <TableColumn fx:id="amountColumn" text="Requested Amount" prefWidth="150" />
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="150" />
            <TableColumn fx:id="scoreColumn" text="Risk Score" prefWidth="100" />
        </columns>
    </TableView>

</VBox>
