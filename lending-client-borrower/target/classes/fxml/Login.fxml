<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.msme.borrower.controllers.LoginController" style="-fx-background-color: -color-bg-subtle;">
    
    <VBox alignment="CENTER" spacing="15.0" styleClass="card" maxWidth="400">
        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>
        
        <Label text="MSME Lending Sandbox" styleClass="title-2" style="-fx-text-fill: -color-accent-emphasis;"/>
        <Label text="Borrower Login" styleClass="text-muted" style="-fx-padding: 0 0 20 0;"/>

        <TextField fx:id="emailField" promptText="Email Address" styleClass="text-field" />
        <PasswordField fx:id="passwordField" promptText="Password" styleClass="text-field" />

        <Button text="Login" maxWidth="Infinity" styleClass="accent" onAction="#handleLogin" />
        
        <Label text="OR" styleClass="text-muted" style="-fx-padding: 10 0 10 0;"/>
        
        <Button text="Create Account" maxWidth="Infinity" onAction="#handleRegister"/>
    </VBox>
</VBox>
